# Webhook signing secret from your Lemon Squeezy store dashboard.
# Settings → Webhooks → (your webhook) → Signing Secret
# Copy this value and paste it here, then rename this file to .env.local
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here
